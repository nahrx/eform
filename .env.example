# ── eForm Backend — contoh konfigurasi ──────────────────────────────
# Salin ke .env lalu sesuaikan.
#
# Untuk development lokal : aplikasi membaca file .env ini secara langsung.
# Untuk deployment Docker : variabel dibaca dari docker-compose.yml (tidak
#   perlu file .env di dalam container; cukup set env di host / CI).
# Override path file .env  : set ENV_FILE=/path/ke/.env sebelum menjalankan.

# HTTP — default 8080
PORT=8080

# PostgreSQL (PG 13+ — butuh gen_random_uuid bawaan core)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eform?sslmode=disable

# JWT — WAJIB diisi di produksi. Kalau kosong, server pakai secret acak
# dan semua token jadi invalid tiap restart. Pakai string panjang acak.
JWT_SECRET=

# Masa berlaku token (jam) — default 24
JWT_TTL_HOURS=24

# CORS — daftar origin dipisah koma, atau * untuk semua (default *).
# Contoh produksi: https://eform.bpskaltim.go.id,https://admin.bpskaltim.go.id
CORS_ORIGINS=*

# URL publik dasar — dipakai untuk menyusun link share (/f/{token})
PUBLIC_BASE_URL=http://localhost:8080

# Folder file aplikasi (login.html, admin.html, builder.html, public.html)
WEB_DIR=web

# Folder landing page publik (index.html) yang disajikan di "/"
PUBLIC_DIR=public

# Superadmin awal — hanya dibuat sekali, saat tabel users masih kosong.
# GANTI password setelah login pertama.
SUPERADMIN_USERNAME=admin
SUPERADMIN_EMAIL=admin@bps.go.id
SUPERADMIN_PASSWORD=admin12345

# ── Khusus Docker Compose ─────────────────────────────────────────────
# Variabel berikut hanya dibaca oleh docker-compose.yml (bukan aplikasi).

# Kredensial database yang dibuat oleh service postgres
POSTGRES_USER=eform
POSTGRES_PASSWORD=eform_secret
POSTGRES_DB=eform

# Port host yang dipetakan ke port 8080 container
APP_PORT=8080

GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=yyyy
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback